# Sunucu yapilandirma ayarlari
PORT=5000
NODE_ENV=development

# MongoDB baglanti adresi
MONGO_URI=mongodb+srv://<kullanici>:<sifre>@cluster.mongodb.net/video-streaming?retryWrites=true&w=majority

# JWT token ayarlari
JWT_SECRET=gizli_anahtar_buraya_gelecek_en_az_32_karakter
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=refresh_gizli_anahtar_32_karakter_olmali
REFRESH_EXPIRE=7d

# Frontend URL (CORS icin)
FRONTEND_URL=http://localhost:5173

# Dosya yukleme limiti (byte cinsinden, 100MB)
MAX_FILE_SIZE=104857600
